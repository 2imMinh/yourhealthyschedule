# .env.example — copy to .env.local (dev) and set real values.

# ---- Database (PostgreSQL) ----
# Pooled connection (PgBouncer) used at runtime:
DATABASE_URL="postgresql://user:pass@host:5432/db?pgbouncer=true&connection_limit=1"
# Direct connection used by Prisma migrations:
DIRECT_URL="postgresql://user:pass@host:5432/db"

# ---- Clerk (auth) ----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_cmVuZXdpbmctY2hlZXRhaC05MC5jbGVyay5hY2NvdW50cy5kZXYk
CLERK_SECRET_KEY=sk_test_BXWX7jSw5Djipe6SVbrQkEJvPsi8gZMYPpDX2tdKbf
CLERK_WEBHOOK_SECRET="whsec_..."          # from Clerk dashboard webhook
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# ---- Stripe (payments) ----
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."          # from `stripe listen` or dashboard
STRIPE_PREMIUM_PRICE_ID="price_..."        # the premium recurring price
NEXT_PUBLIC_STRIPE_PREMIUM_PRICE_ID="price_..."  # same id, exposed to client

# ---- OpenAI (AI layer) ----
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Dev seed (optional) ----
SEED_USER_ID="user_seed_demo"
SEED_USER_EMAIL="demo@example.com"
